#!/bin/bash
# Legacy alias for blockdown — kept for backwards compatibility.
BLOCKDOWN="/usr/local/bin/blockdown"

if [[ ! -x "$BLOCKDOWN" ]]; then
    echo "blockdown CLI not installed. Run the Blockdown installer first." >&2
    exit 1
fi

case "${1:-}" in
    host)
        shift
        exec "$BLOCKDOWN" host "$@"
        ;;
    ban)
        shift
        exec "$BLOCKDOWN" app "$@"
        ;;
    apply)
        exec "$BLOCKDOWN" apply
        ;;
    dns)
        echo "The 'dns' subcommand has been removed." >&2
        echo "Set up the web filter in the Blockdown TUI, or run: sudo ./scripts/install-dns.sh" >&2
        exit 1
        ;;
    *)
        echo "Note: 'pin' is deprecated. Use 'sudo blockdown' instead." >&2
        echo "" >&2
        echo "  pin host ...  →  blockdown host ..." >&2
        echo "  ban ...       →  blockdown app ..." >&2
        exit 1
        ;;
esac
