# =========================================================
# PART A: Allow port 53 ONLY to CleanBrowsing; block everything else
# =========================================================
# macOS PF's `rdr` rules only translate packets ARRIVING ON an interface, not
# packets ORIGINATING from this Mac. Redirecting local outgoing DNS queries
# would require divert(4) or a transparent proxy (out of scope).
#
# Instead, we use simple block/pass rules:
#   - Allow port 53 to CleanBrowsing's IPs (for apps that explicitly target them)
#   - Block all other port 53 traffic
#
# Legitimate DNS goes through the system resolver on port 443 (DoH via the
# CleanBrowsing profile), so blocking port 53 to other servers doesn't break
# normal traffic — it only catches apps trying to bypass the system resolver.

pass out quick inet proto { tcp, udp } from any to { 185.228.168.10, 185.228.169.11 } port 53
block drop quick inet proto { tcp, udp } from any to any port 53

# =========================================================
# PART A2: Block all IPv6 DNS (port 53)
# =========================================================
# Forces IPv6-DNS-bypass apps to fall back to IPv4 (which is then blocked or
# allowed to CleanBrowsing by Part A above).

block drop quick inet6 proto { tcp, udp } from any to any port 53

# =========================================================
# PART B: Block DNS-over-TLS (port 853) globally
# =========================================================

block drop quick proto { tcp, udp } from any to any port 853

